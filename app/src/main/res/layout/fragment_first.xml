<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ChannelsFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/text_connected_device_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_connected_device"
            android:textColor="#666666"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/edit_mac_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="?attr/editTextBackground"
            android:paddingStart="12dp"
            android:paddingTop="14dp"
            android:paddingEnd="12dp"
            android:paddingBottom="14dp"
            android:text="@string/text_device_not_selected"
            android:textSize="16sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_scan_devices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_scan_devices" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_read_real"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_read_real" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edit_channel_delete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_delete_channel"
                android:inputType="number" />

            <Button
                android:id="@+id/button_delete_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/btn_delete" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/button_write_real"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_write_real" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:maxLines="4"
            android:text="@string/text_not_read"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/text_channels_empty_big"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingTop="24dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp"
        android:text="@string/channel_table_empty"
        android:textSize="22sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/layout_channels_table_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="56dp"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TableLayout
                android:id="@+id/table_channels_header_fixed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="0" />

            <ScrollView
                android:id="@+id/scroll_channels_fixed_body"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <TableLayout
                    android:id="@+id/table_channels_fixed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0" />
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.byf3332.uv5rminicps.LinkedHorizontalScrollView
                android:id="@+id/hscroll_channels_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">

                <TableLayout
                    android:id="@+id/table_channels_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:stretchColumns="0" />
            </com.byf3332.uv5rminicps.LinkedHorizontalScrollView>

            <com.byf3332.uv5rminicps.LinkedHorizontalScrollView
                android:id="@+id/hscroll_channels_body"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true"
                android:overScrollMode="never">

                <ScrollView
                    android:id="@+id/scroll_channels_body"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:fillViewport="true"
                    android:overScrollMode="never">

                    <TableLayout
                        android:id="@+id/table_channels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:stretchColumns="0" />
                </ScrollView>
            </com.byf3332.uv5rminicps.LinkedHorizontalScrollView>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
